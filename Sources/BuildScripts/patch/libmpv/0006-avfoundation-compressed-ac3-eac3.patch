+#define IEC61937_HEADER_SIZE 8
+#define IEC61937_AC3  0x01
+#define IEC61937_EAC3 0x15
+
+// One IEC 61937 burst carries one (E-)AC-3 access unit worth of audio.
+#define SPDIF_FRAMES_PER_BURST 1536
+
+// Once the system renderer rejects a compressed format, permanently fall
+// back to PCM for it (per process): ao_request_reload() would otherwise
+// retry the same spdif format forever, while a failing init makes the
+// player core fall back to PCM decoding.
+static bool spdif_format_latch[2];
+
+static int spdif_latch_index(int format)
+{
+    return format == AF_FORMAT_S_EAC3;
+}
+
 static int64_t CMTimeGetNanoseconds(CMTime time)
 {
     time = CMTimeConvertScale(time, 1000000000, kCMTimeRoundingMethod_Default);
@@ -58,12 +86,337 @@ static CMTime CMTimeFromNanoseconds(int64_t time)
     return CMTimeMake(time, 1000000000);
 }
 
+// Latch the failing format and force a reinit; init() will then reject the
+// format and the player core falls back to PCM decoding.
+static void spdif_reload(struct ao *ao)
+{
+    struct priv *p = ao->priv;
+
+    spdif_format_latch[spdif_latch_index(ao->format)] = true;
+    [p->renderer stopRequestingMediaData];
+    ao_request_reload(ao);
+}
+
+static uint32_t spdif_get_bits(const uint8_t *buf, int offset, int n)
+{
+    uint32_t v = 0;
+    for (int i = offset; i < offset + n; i++)
+        v = (v << 1) | ((buf[i >> 3] >> (7 - (i & 7))) & 1);
+    return v;
+}
+
+struct spdif_bsi {
+    int rate;
+    int channels;
+    AudioChannelLayoutTag layout_tag;
+};
+
+// Advisory layout for the decoder output; 0 = omit the layout.
+static AudioChannelLayoutTag spdif_layout_tag(int acmod, int lfeon, int channels)
+{
+    if (channels == 8)
+        return kAudioChannelLayoutTag_MPEG_7_1_C;
+    switch (acmod) {
+    case 1:
+        return lfeon ? 0 : kAudioChannelLayoutTag_Mono;
+    case 0: // dual mono
+    case 2:
+        return lfeon ? 0 : kAudioChannelLayoutTag_Stereo;
+    case 7:
+        return lfeon ? kAudioChannelLayoutTag_MPEG_5_1_A
+                     : kAudioChannelLayoutTag_MPEG_5_0_A;
+    default:
+        return 0;
+    }
+}
+
+static OSStatus spdif_create_format_description(struct ao *ao, int channels,
+                                                AudioChannelLayoutTag layout_tag,
+                                                CMAudioFormatDescriptionRef *format_description)
+{
+    struct priv *p = ao->priv;
+    AudioStreamBasicDescription asbd = {
+        .mSampleRate       = p->spdif_rate,
+        .mFormatID         = p->spdif_format_id,
+        .mFramesPerPacket  = SPDIF_FRAMES_PER_BURST,
+        .mChannelsPerFrame = channels,
+    };
+    AudioChannelLayout layout = { .mChannelLayoutTag = layout_tag };
+    return CMAudioFormatDescriptionCreate(
+        NULL,
+        &asbd,
+        layout_tag ? sizeof(layout) : 0,
+        layout_tag ? &layout : NULL,
+        0,
+        NULL,
+        NULL,
+        format_description
+    );
+}
+
+// Read sample rate and channel count from the first syncframe's bitstream
+// info. In both AC-3 and E-AC-3 bsid is located at bit 40.
+static bool spdif_parse_bsi(const uint8_t *frame, int size, struct spdif_bsi *out)
+{
+    static const int fscod_rates[] = {48000, 44100, 32000};
+    static const uint8_t acmod_channels[] = {2, 1, 2, 3, 3, 4, 4, 5};
+
+    if (size < 8 || frame[0] != 0x0b || frame[1] != 0x77)
+        return false;
+
+    int bsid = spdif_get_bits(frame, 40, 5);
+    if (bsid <= 10) {
+        // AC-3: syncword(16) crc1(16) fscod(2) frmsizecod(6) bsid(5)
+        //       bsmod(3) acmod(3) [mix levels] lfeon(1)
+        int fscod = spdif_get_bits(frame, 32, 2);
+        if (fscod > 2)
+            return false;
+        int acmod = spdif_get_bits(frame, 48, 3);
+        int skip = 0;
+        if ((acmod & 1) && acmod != 1)
+            skip += 2; // cmixlev
+        if (acmod & 4)
+            skip += 2; // surmixlev
+        if (acmod == 2)
+            skip += 2; // dsurmod
+        int lfeon = spdif_get_bits(frame, 51 + skip, 1);
+        out->rate = fscod_rates[fscod];
+        out->channels = acmod_channels[acmod] + lfeon;
+        out->layout_tag = spdif_layout_tag(acmod, lfeon, out->channels);
+    } else if (bsid <= 16) {
+        // E-AC-3: syncword(16) strmtyp(2) substreamid(3) frmsiz(11) fscod(2)
+        //         [fscod2(2)|numblkscod(2)] acmod(3) lfeon(1) bsid(5)
+        int fscod = spdif_get_bits(frame, 32, 2);
+        if (fscod == 3) {
+            int fscod2 = spdif_get_bits(frame, 34, 2);
+            if (fscod2 > 2)
+                return false;
+            out->rate = fscod_rates[fscod2] / 2;
+        } else {
+            out->rate = fscod_rates[fscod];
+        }
+        int acmod = spdif_get_bits(frame, 36, 3);
+        int lfeon = spdif_get_bits(frame, 39, 1);
+        out->channels = acmod_channels[acmod] + lfeon;
+        // a dependent substream (strmtyp == 1) directly after the
+        // independent frame extends the layout (typically to 7.1)
+        int frame_bytes = (spdif_get_bits(frame, 18, 11) + 1) * 2;
+        if (size >= frame_bytes + 8 &&
+            frame[frame_bytes] == 0x0b && frame[frame_bytes + 1] == 0x77 &&
+            spdif_get_bits(frame + frame_bytes, 16, 2) == 1)
+            out->channels = 8;
+        out->layout_tag = spdif_layout_tag(acmod, lfeon, out->channels);
+    } else {
+        return false;
+    }
+    return true;
+}
+
+// Validate the stream against the format description created in init() and
+// refine the channel count once. Returns false if the AO is reloading.
+static bool spdif_check_bsi(struct ao *ao, const uint8_t *frame, int size)
+{
+    struct priv *p = ao->priv;
+    struct spdif_bsi bsi;
+
+    if (p->spdif_bsi_checked)
+        return true;
+
+    if (!spdif_parse_bsi(frame, size, &bsi)) {
+        MP_WARN(ao, "failed to parse bitstream info; assuming 5.1\n");
+        p->spdif_bsi_checked = true;
+        return true;
+    }
+    if (bsi.rate != p->spdif_rate) {
+        // ad_spdif hardcodes the 4x IEC rate for EAC3, so the core paces
+        // the stream assuming 48 kHz; other rates cannot play correctly
+        MP_ERR(ao, "stream rate %d Hz does not match the IEC rate; "
+               "falling back to PCM\n", bsi.rate);
+        spdif_reload(ao);
+        return false;
+    }
+    CMAudioFormatDescriptionRef format_description = NULL;
+    if (spdif_create_format_description(ao, bsi.channels, bsi.layout_tag,
+                                        &format_description) == noErr) {
+        CFRelease(p->format_description);
+        p->format_description = format_description;
+    }
+    MP_INFO(ao, "bitstream: %d ch, %d Hz, layout tag 0x%x\n",
+            bsi.channels, bsi.rate, (unsigned)bsi.layout_tag);
+    p->spdif_bsi_checked = true;
+    return true;
+}
+
+// Package one IEC 61937 burst payload as a compressed sample and enqueue it.
+// Returns false if the AO is reloading and feeding should stop.
+static bool spdif_enqueue_burst(struct ao *ao, const uint8_t *payload, int payload_len)
+{
+    struct priv *p = ao->priv;
+    CMBlockBufferRef block_buffer = NULL;
+    CMSampleBufferRef sample_buffer = NULL;
+    OSStatus err;
+
+    int alloc_len = MP_ALIGN_UP(payload_len, 2);
+    uint8_t *data = CFAllocatorAllocate(NULL, alloc_len, 0);
+    if (!data)
+        return true;
+    // the spdif muxer emits 16-bit LE words; swap back to the raw bitstream
+    for (int i = 0; i < alloc_len; i += 2) {
+        data[i]     = payload[i + 1];
+        data[i + 1] = payload[i];
+    }
+    if (data[0] != 0x0b || data[1] != 0x77) {
+        MP_WARN(ao, "discarding burst without syncframe\n");
+        CFAllocatorDeallocate(NULL, data);
+        return true;
+    }
+
+    if (!spdif_check_bsi(ao, data, payload_len)) {
+        CFAllocatorDeallocate(NULL, data);
+        return false;
+    }
+
+    if ((err = CMBlockBufferCreateWithMemoryBlock(
+        NULL,
+        data,
+        alloc_len,
+        NULL,
+        NULL,
+        0,
+        payload_len,
+        0,
+        &block_buffer
+    )) != noErr) {
+        CFAllocatorDeallocate(NULL, data);
+        MP_FATAL(ao, "failed to create block buffer\n");
+        MP_VERBOSE(ao, "CMBlockBufferCreateWithMemoryBlock returned %d\n", err);
+        spdif_reload(ao);
+        return false;
+    }
+
+    AudioStreamPacketDescription packet = {
+        .mStartOffset = 0,
+        .mVariableFramesInPacket = 0,
+        .mDataByteSize = payload_len,
+    };
+    if ((err = CMAudioSampleBufferCreateReadyWithPacketDescriptions(
+        NULL,
+        block_buffer,
+        p->format_description,
+        1,
+        CMTimeFromNanoseconds(p->next_burst_pts),
+        &packet,
+        &sample_buffer
+    )) != noErr) {
+        CFRelease(block_buffer);
+        MP_FATAL(ao, "failed to create sample buffer\n");
+        MP_VERBOSE(ao, "CMAudioSampleBufferCreateReadyWithPacketDescriptions returned %d\n", err);
+        spdif_reload(ao);
+        return false;
+    }
+
+    [p->renderer enqueueSampleBuffer:sample_buffer];
+    CFRelease(block_buffer);
+    CFRelease(sample_buffer);
+
+    p->next_burst_pts += CMTimeGetNanoseconds(CMTimeMake(SPDIF_FRAMES_PER_BURST, p->spdif_rate));
+    return true;
+}
+
+static void feed_spdif(struct ao *ao)
+{
+    struct priv *p = ao->priv;
+    int samplerate = ao->samplerate;
+    int sstride = ao->sstride;
+
+    if ([p->renderer status] == AVQueuedSampleBufferRenderingStatusFailed) {
+        NSError *error = [p->renderer error];
+        MP_ERR(ao, "renderer failed to accept the compressed stream: %s (%s:%ld)\n",
+               error ? [[error localizedDescription] UTF8String] : "unknown",
+               error ? [[error domain] UTF8String] : "-",
+               error ? (long)[error code] : 0);
+        MP_ERR(ao, "falling back to PCM\n");
+        spdif_reload(ao);
+        return;
+    }
+
+    int request_sample_count = samplerate / 10;
+    if ((p->stash_size - p->stash_len) / sstride < request_sample_count)
+        request_sample_count = (p->stash_size - p->stash_len) / sstride;
+
+    int64_t cur_time_av = CMTimeGetNanoseconds([p->synchronizer currentTime]);
+    int64_t cur_time_mp = mp_time_ns();
+    int64_t end_time_av = MPMAX(p->end_time_av, cur_time_av);
+    int64_t time_delta = CMTimeGetNanoseconds(CMTimeMake(request_sample_count, samplerate));
+    bool eof;
+    void *data[] = {p->stash + p->stash_len};
+    int real_sample_count = ao_read_data(ao, data, request_sample_count, end_time_av - cur_time_av + cur_time_mp + time_delta, &eof, false, true);
+    if (eof) {
+        [p->renderer stopRequestingMediaData];
+        ao_stop_streaming(ao);
+    }
+    if (real_sample_count == 0)
+        return;
+
+    // keep the burst clock in lockstep with the read clock
+    if (p->next_burst_pts < 0) {
+        p->next_burst_pts = end_time_av;
+    } else if (p->end_time_av >= 0 && end_time_av > p->end_time_av) {
+        p->next_burst_pts += end_time_av - p->end_time_av;
+    }
+    p->stash_len += real_sample_count * sstride;
+
+    // extract every complete IEC 61937 burst
+    int pos = 0;
+    while (true) {
+        while (pos + IEC61937_HEADER_SIZE <= p->stash_len &&
+               !(p->stash[pos] == 0x72 && p->stash[pos + 1] == 0xf8 &&
+                 p->stash[pos + 2] == 0x1f && p->stash[pos + 3] == 0x4e))
+            pos++;
+        if (pos + IEC61937_HEADER_SIZE > p->stash_len)
+            break;
+        int data_type = p->stash[pos + 4] & 0x7f;
+        int pd = p->stash[pos + 6] | (p->stash[pos + 7] << 8);
+        if (!(data_type == IEC61937_AC3 && p->spdif_format_id == kAudioFormatAC3) &&
+            !(data_type == IEC61937_EAC3 && p->spdif_format_id == kAudioFormatEnhancedAC3)) {
+            pos++;
+            continue;
+        }
+        // Pd is the payload length in bits for AC3 and in bytes for EAC3
+        int payload_len = data_type == IEC61937_AC3 ? pd / 8 : pd;
+        if (payload_len < 8 || payload_len > p->spdif_burst_size - IEC61937_HEADER_SIZE) {
+            pos++;
+            continue;
+        }
+        if (pos + IEC61937_HEADER_SIZE + MP_ALIGN_UP(payload_len, 2) > p->stash_len)
+            break; // incomplete burst; wait for more data
+        if (!spdif_enqueue_burst(ao, p->stash + pos + IEC61937_HEADER_SIZE, payload_len))
+            return;
+        pos += IEC61937_HEADER_SIZE + MP_ALIGN_UP(payload_len, 2);
+    }
+    if (pos > 0) {
+        memmove(p->stash, p->stash + pos, p->stash_len - pos);
+        p->stash_len -= pos;
+    }
+    if (p->stash_len > p->spdif_burst_size * 3) {
+        MP_WARN(ao, "no IEC 61937 sync found; discarding %d bytes\n", p->stash_len);
+        p->stash_len = 0;
+    }
+
+    p->end_time_av = end_time_av + CMTimeGetNanoseconds(CMTimeMake(real_sample_count, samplerate));
+}
