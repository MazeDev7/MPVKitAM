diff --git a/libavcodec/ac3_parser.c b/libavcodec/ac3_parser.c
index a8bc3af..89d6ddb 100644
--- a/libavcodec/ac3_parser.c
+++ b/libavcodec/ac3_parser.c
@@ -33,6 +33,7 @@
-#include "get_bits.h"
-
-
-#define AC3_HEADER_SIZE 7
-
+#include "get_bits.h"
+#include "put_bits.h"
+
+
+#define AC3_HEADER_SIZE 7
+
 #if CONFIG_AC3_PARSER
@@ -440,6 +441,128 @@ int av_ac3_parse_header(const uint8_t *buf, size_t size,
     return 0;
 }
 
+int av_eac3_make_dec3(const uint8_t *buf, size_t size,
+                      uint8_t *dec3, size_t dec3_capacity,
+                      int *sample_rate, int *channels, int *num_blocks,
+                      int *num_dep_sub_out, int *chan_loc_out,
+                      int *complexity_index_type_a, int *joc)
+{
+    GetBitContext gb;
+    AC3HeaderInfo hdr;
+    uint16_t chan_loc = 0;
+    uint8_t num_dep_sub = 0, group_num_dep_sub = 0;
+    int offset, err, dec3_size, total_blocks, data_rate;
+    int complexity, has_joc;
+    PutBitContext pbc;
+
+    err = init_get_bits8(&gb, buf, size);
+    if (err < 0)
+        return AVERROR_INVALIDDATA;
+    err = ff_ac3_parse_header(&gb, &hdr);
+    if (err < 0)
+        return AVERROR_INVALIDDATA;
+    if (hdr.bitstream_id <= 10 ||
+        (hdr.frame_type != EAC3_FRAME_TYPE_INDEPENDENT &&
+         hdr.frame_type != EAC3_FRAME_TYPE_AC3_CONVERT) ||
+        hdr.substreamid != 0)
+        return AVERROR_INVALIDDATA;
+
+    /* IEC 61937 may concatenate several short independent frames into one
+     * 1536-sample burst. Extract the first stream configuration, merge its
+     * dependent channel map, and account for every independent frame's
+     * duration without treating repetitions as extra substreams. */
+    total_blocks = hdr.num_blocks;
+    data_rate = hdr.bit_rate / 1000;
+    complexity = hdr.complexity_index_type_a;
+    has_joc = hdr.eac3_extension_type_a && complexity;
+    offset = hdr.frame_size;
+    while (offset < size) {
+        AC3HeaderInfo next;
+
+        err = init_get_bits8(&gb, buf + offset, size - offset);
+        if (err < 0 || ff_ac3_parse_header(&gb, &next) < 0 ||
+            next.substreamid != hdr.substreamid || next.frame_size <= 0 ||
+            next.frame_size > size - offset)
+            return AVERROR_INVALIDDATA;
+
+        if (next.frame_type == EAC3_FRAME_TYPE_DEPENDENT) {
+            if (group_num_dep_sub == 15)
+                return AVERROR_INVALIDDATA;
+            group_num_dep_sub++;
+            if (next.channel_map_present)
+                chan_loc |= (next.channel_map >> 5) & 0x1f;
+            else
+                chan_loc |= next.channel_mode;
+        } else if (next.frame_type == EAC3_FRAME_TYPE_INDEPENDENT ||
+                   next.frame_type == EAC3_FRAME_TYPE_AC3_CONVERT) {
+            if (next.sr_code != hdr.sr_code ||
+                next.bitstream_id != hdr.bitstream_id ||
+                next.bitstream_mode != hdr.bitstream_mode ||
+                next.channel_mode != hdr.channel_mode ||
+                next.lfe_on != hdr.lfe_on || total_blocks + next.num_blocks > 6)
+                return AVERROR_INVALIDDATA;
+            num_dep_sub = FFMAX(num_dep_sub, group_num_dep_sub);
+            group_num_dep_sub = 0;
+            total_blocks += next.num_blocks;
+            data_rate = FFMAX(data_rate, next.bit_rate / 1000);
+            complexity = FFMAX(complexity, next.complexity_index_type_a);
+            has_joc |= next.eac3_extension_type_a &&
+                       next.complexity_index_type_a;
+        } else {
+            return AVERROR_INVALIDDATA;
+        }
+        offset += next.frame_size;
+    }
+    if (offset != size)
+        return AVERROR_INVALIDDATA;
+    num_dep_sub = FFMAX(num_dep_sub, group_num_dep_sub);
+
+    dec3_size = 6 + 2 * !!complexity;
+    if (!dec3 || dec3_capacity < dec3_size)
+        return AVERROR(ENOSPC);
+
+    init_put_bits(&pbc, dec3, dec3_capacity);
+    put_bits(&pbc, 13, FFMIN(data_rate, 8191));
+    put_bits(&pbc, 3, 0); /* num_ind_sub: one independent substream */
+    put_bits(&pbc, 2, hdr.sr_code);
+    put_bits(&pbc, 5, hdr.bitstream_id);
+    put_bits(&pbc, 1, 0); /* reserved */
+    put_bits(&pbc, 1, 0); /* asvc */
+    put_bits(&pbc, 3, hdr.bitstream_mode);
+    put_bits(&pbc, 3, hdr.channel_mode);
+    put_bits(&pbc, 1, hdr.lfe_on);
+    put_bits(&pbc, 3, 0); /* reserved */
+    put_bits(&pbc, 4, num_dep_sub);
+    if (num_dep_sub)
+        put_bits(&pbc, 9, chan_loc);
+    else
+        put_bits(&pbc, 1, 0); /* reserved */
+    if (complexity) {
+        put_bits(&pbc, 7, 0); /* reserved */
+        put_bits(&pbc, 1, 1); /* flag_ec3_extension_type_a */
+        put_bits(&pbc, 8, complexity);
+    }
+    flush_put_bits(&pbc);
+    dec3_size = put_bytes_output(&pbc);
+
+    if (sample_rate)
+        *sample_rate = hdr.sample_rate;
+    if (channels)
+        *channels = hdr.channels;
+    if (num_blocks)
+        *num_blocks = total_blocks;
+    if (num_dep_sub_out)
+        *num_dep_sub_out = num_dep_sub;
+    if (chan_loc_out)
+        *chan_loc_out = chan_loc;
+    if (complexity_index_type_a)
+        *complexity_index_type_a = complexity;
+    if (joc)
+        *joc = has_joc;
+
+    return dec3_size;
+}
+
 static int ac3_sync(uint64_t state, int *need_next_header, int *new_frame_start)
 {
     int err;
@@ -498,4 +621,13 @@ int av_ac3_parse_header(const uint8_t *buf, size_t size,
 {
     return AVERROR(ENOSYS);
 }
+
+int av_eac3_make_dec3(const uint8_t *buf, size_t size,
+                      uint8_t *dec3, size_t dec3_capacity,
+                      int *sample_rate, int *channels, int *num_blocks,
+                      int *num_dep_sub, int *chan_loc,
+                      int *complexity_index_type_a, int *joc)
+{
+    return AVERROR(ENOSYS);
+}
 #endif
diff --git a/libavcodec/ac3_parser.h b/libavcodec/ac3_parser.h
index ff8cc4c..e60af69 100644
--- a/libavcodec/ac3_parser.h
+++ b/libavcodec/ac3_parser.h
@@ -32,5 +32,18 @@
 int av_ac3_parse_header(const uint8_t *buf, size_t size,
                         uint8_t *bitstream_id, uint16_t *frame_size);
 
+/**
+ * Build the EC3SpecificBox (dec3) payload for a complete E-AC-3 access unit.
+ * The input must contain complete independent frames and their concatenated
+ * dependent frames. This preserves extension type A / JOC signaling.
+ *
+ * @return dec3 payload size on success or a negative AVERROR value.
+ */
+int av_eac3_make_dec3(const uint8_t *buf, size_t size,
+                      uint8_t *dec3, size_t dec3_capacity,
+                      int *sample_rate, int *channels, int *num_blocks,
+                      int *num_dep_sub, int *chan_loc,
+                      int *complexity_index_type_a, int *joc);
+
 
 #endif /* AVCODEC_AC3_PARSER_H */
