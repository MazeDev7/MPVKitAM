From 08454479e7147e01d22a3bd7a1b9e87a841f9714 Mon Sep 17 00:00:00 2001
From: edde746 <86283021+edde746@users.noreply.github.com>
Date: Wed, 10 Jun 2026 10:01:17 +0200
Subject: [PATCH] videotoolbox: never signal Dolby Vision metadata compression
 in dvvC

Legacy MPEG-TS muxers fill the old-spec reserved bits after the
compatibility id in the DOVI video stream descriptor with ones, which
FFmpeg's mpegts demuxer reads back as dv_md_compression = 3 (extended).
Copying that into the dvvC handed to VideoToolbox makes
VTDecompressionSessionCreate reject the session with
kVTVideoDecoderUnsupportedDataFormatErr (-12910), silently dropping
4K Dolby Vision TS remuxes to software decode.

Backward-compatible profiles (the only ones routed to the Apple Dolby
Vision decoder here) must signal uncompressed metadata per the Dolby
spec, so never set the compression bits.
---
 libavcodec/videotoolbox.c | 12 +++++++-----
 1 file changed, 7 insertions(+), 5 deletions(-)

diff --git a/libavcodec/videotoolbox.c b/libavcodec/videotoolbox.c
index 2995eea..5d23e4d 100644
--- a/libavcodec/videotoolbox.c
+++ b/libavcodec/videotoolbox.c
@@ -1010,7 +1010,7 @@ static CFDataRef videotoolbox_dovi_extradata_create(const AVDOVIDecoderConfigura
 {
     uint8_t buf[24] = { 0 };
     uint16_t flags;
-    int profile, el_present, bl_compatibility_id, compression;
+    int profile, el_present, bl_compatibility_id;
 
     if (!videotoolbox_dovi_is_apple_hevc(dovi))
         return NULL;
@@ -1018,11 +1018,9 @@ static CFDataRef videotoolbox_dovi_extradata_create(const AVDOVIDecoderConfigura
     profile = videotoolbox_dovi_effective_profile(dovi);
     el_present = dovi->el_present_flag;
     bl_compatibility_id = dovi->dv_bl_signal_compatibility_id;
-    compression = dovi->dv_md_compression;
     if (videotoolbox_dovi_needs_p81_conversion(dovi)) {
         el_present = 0;
         bl_compatibility_id = 1;
-        compression = AV_DOVI_COMPRESSION_NONE;
     }
 
     buf[0] = dovi->dv_version_major;
@@ -1033,8 +1031,12 @@ static CFDataRef videotoolbox_dovi_extradata_create(const AVDOVIDecoderConfigura
             (!!el_present) << 1 |
             !!dovi->bl_present_flag;
     AV_WB16(buf + 2, flags);
-    buf[4] = (bl_compatibility_id & 0x0f) << 4 |
-             (compression & 0x03) << 2;
+    /* Always signal uncompressed DV metadata. Legacy MPEG-TS muxers fill the
+     * old-spec reserved bits after the compatibility id with ones, which the
+     * mpegts demuxer reads back as dv_md_compression = extended; VideoToolbox
+     * rejects such dvvC atoms with kVTVideoDecoderUnsupportedDataFormatErr.
+     * Backward-compatible profiles must signal 0 here per the Dolby spec. */
+    buf[4] = (bl_compatibility_id & 0x0f) << 4;
 
     return CFDataCreate(kCFAllocatorDefault, buf, sizeof(buf));
 }
